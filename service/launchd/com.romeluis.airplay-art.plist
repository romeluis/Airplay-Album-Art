<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  LaunchAgent for the AirPlay Album Art service. See ../../design.md.

  1. Adjust WorkingDirectory below to this repo's service/ path.
  2. cp com.romeluis.airplay-art.plist ~/Library/LaunchAgents/
  3. launchctl load ~/Library/LaunchAgents/com.romeluis.airplay-art.plist
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.romeluis.airplay-art</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/bin/uv</string>
        <string>run</string>
        <string>airplay-art</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/romeluis/Projects/Airplay Album Art/service</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/romeluis/Library/Logs/airplay-art.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/romeluis/Library/Logs/airplay-art.log</string>
</dict>
</plist>
