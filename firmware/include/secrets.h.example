// Copy this file to secrets.h (git-ignored) and fill in your values.
#pragma once

#define WIFI_SSID     "your-wifi-ssid"
#define WIFI_PASSWORD "your-wifi-password"

// Mac mini running the airplay-art service (see ../../design.md).
// Optional: the server's Bonjour name (scutil --get LocalHostName, no
// ".local"). Resolved at boot so DHCP reassignments don't strand the
// display; SERVER_HOST is the fallback if the lookup fails.
#define SERVER_MDNS_NAME "your-mac-name"
#define SERVER_HOST "192.168.1.10"
#define SERVER_PORT 8765
#define SERVER_PATH "/"
